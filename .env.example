# Application
APP_ENV=development
PORT=8080

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/youtube_automation?sslmode=disable

# Queue
QUEUE_BACKEND=memory
REDIS_URL=redis://localhost:6379

# Storage
STORAGE_BACKEND=local
STORAGE_BUCKET=youtube-automation
STORAGE_BASE_DIR=./storage

# AWS (for production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Voice Provider
VOICE_PROVIDER=mock
POLLY_DEFAULT_VOICE=Matthew
POLLY_ENGINE=neural  # Options: standard, neural, generative (generative = most natural but most expensive)

# Image Provider
IMAGE_PROVIDER=mock

# Render Settings
RENDER_FPS=30
RENDER_WIDTH=1080
RENDER_HEIGHT=1920
FFMPEG_PATH=ffmpeg

# Review Settings
REVIEW_REQUIRED_DEFAULT=true
