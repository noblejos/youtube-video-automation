# Voice Provider Configuration
# Options: "mock" or "polly"
VOICE_PROVIDER=polly

# AWS Configuration (required for Polly)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
POLLY_DEFAULT_VOICE=Ayanda
POLLY_ENGINE=standard

# Image Provider Configuration
# Options: "mock" or "openai"
IMAGE_PROVIDER=openai

# OpenAI Configuration (required for image generation)
OPENAI_API_KEY=sk-your-openai-api-key
# Image model options: dall-e-2, dall-e-3, gpt-image-1, gpt-image-1-mini
OPENAI_MODEL=gpt-image-1-mini

# LLM Configuration (for AI-generated scripts/scenes)
# Options: "mock" or "openai"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Render Settings
# Set to "true" to use mock render (placeholder video), "false" for real FFmpeg render
USE_MOCK_RENDER=false
